# MySQL — sesuaikan dengan kredensial database kamu
DATABASE_URL="mysql://root:password@localhost:3306/pos_saas"

# JWT
JWT_ACCESS_SECRET="ganti-dengan-secret-acak-yang-panjang"
JWT_REFRESH_SECRET="ganti-dengan-secret-lain-yang-panjang"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="30d"

# Super admin awal (dipakai oleh prisma/seed.ts)
SEED_SUPER_ADMIN_EMAIL="superadmin@pos.com"
SEED_SUPER_ADMIN_PASSWORD="ChangeMe123!"

# WhatsApp Gateway — notifikasi otomatis saat tenant di-approve/ditolak.
# WHATSAPP_DEVICE_ID di sini cuma jadi DEFAULT AWAL; Super Admin bisa mengganti
# Device ID kapan saja lewat Admin Panel > Pengaturan > WhatsApp tanpa redeploy.
WHATSAPP_API_URL="https://wa.sicerdiq.my.id/send/message"
WHATSAPP_DEVICE_ID="12722d7b-0836-477c-9800-cfc4a12f1731"
WHATSAPP_AUTH_USERNAME="admin"
WHATSAPP_AUTH_PASSWORD="StrongPassword123!"
WHATSAPP_ENABLED="true"
